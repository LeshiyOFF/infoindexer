<!--
  Default Profile Override
  @remarks
  Overrides default profile with increased memory limit.
  Named zzz- to load AFTER default-user.xml from Docker image.
-->
<clickhouse>
  <profiles>
    <default>
      <max_memory_usage>10000000000</max_memory_usage>
      <max_execution_time>3600</max_execution_time>
    </default>
  </profiles>
</clickhouse>
