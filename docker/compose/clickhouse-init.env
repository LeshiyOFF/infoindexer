# ClickHouse Init Service Environment
# Source: docker/compose/clickhouse-init.env

# Inherits from base.env:
# - CLICKHOUSE_HOST
# - CLICKHOUSE_DB
# - CLICKHOUSE_USER
# - CLICKHOUSE_PASSWORD
# - REDIS_HOST
# - NODE_ENV

# ClickHouse Init Specific
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
MAX_RETRIES=30
RETRY_INTERVAL=2
