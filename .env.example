# INFOINDEXER - Параметры внутренней сети Docker Compose
# Эти значения соответствуют именам сервисов в docker-compose.yml

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=default

# --- ClickHouse RBAC (Iteration 10) ---
# Пароли для создания пользователей в ClickHouse
# Оставьте пустым для использования default пользователя (не рекомендуется для продакшена)
CLICKHOUSE_ADMIN_PASSWORD=change_me_admin
CLICKHOUSE_WORKER_PASSWORD=change_me_worker
CLICKHOUSE_API_PASSWORD=change_me_api
# Отключить пользователя default (рекомендуется для продакшена)
CLICKHOUSE_DISABLE_DEFAULT=false

# --- Redis ---
REDIS_HOST=redis

# --- Auth ---
# Пароль для выполнения операций синхронизации и обогащения данных (обязательно)
ADMIN_PASSWORD=YOUR_SECURE_PASSWORD

# --- Proxy (опционально, для egrul-sync-worker) ---
# SOCKS_PROXY_URL=socks5://user:pass@host:port  (socks5h — DNS через прокси)

# --- Общие ---
# Используется воркерами для управления нагрузкой
BATCH_SIZE=10000

# SOCKS_PROXY_URL=socks5://user:pass@ip:port
